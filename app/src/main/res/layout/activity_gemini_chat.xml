<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E88E5"
        app:title="Gemini AI"
        app:titleTextColor="@color/white"
        >
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/back"
            android:layout_width="35dp"
            android:layout_height="wrap_content"
            android:src="@drawable/back_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.5"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="149dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Gemini AI "
            android:textColor="@color/white"
            android:textSize="25sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:padding="8dp" />

        <ProgressBar
            android:id="@+id/geminiProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/msgBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/black"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/edit_text_style"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="8dp">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/GeminiPrompt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Ask Gemini..."
                android:inputType="textShortMessage"
                android:minHeight="45dp"
                android:padding="10dp"
                android:textColorHint="#99000000" />

            <ImageView
                android:id="@+id/media"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/open_folder1"
                app:tint="#808080" />

            <ImageView
                android:id="@+id/camera"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"

                android:src="@drawable/camera1"
                app:tint="#808080" />

            <ImageView
                android:id="@+id/mic"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/mic1"
                app:tint="#808080" />
        </LinearLayout>

        <ImageView
            android:id="@+id/sendPrompt"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/circle_blue_bg"
            android:padding="12dp"
            android:src="@drawable/send"
            app:tint="@color/white" />
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/previewContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_blue_bg" />

        <ImageView
            android:id="@+id/btnRemoveImage"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignTop="@id/imagePreview"
            android:layout_alignEnd="@id/imagePreview"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/circle_blue_bg"
            android:elevation="2dp" />
    </RelativeLayout>
</LinearLayout>